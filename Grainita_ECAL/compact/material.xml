
<materials>

    <material name="Vacuum">
      <D type="density" unit="g/cm3" value="0.0000000001" />
      <fraction n="0.754" ref="N"/>
      <fraction n="0.234" ref="O"/>
      <fraction n="0.012" ref="Ar"/>
    </material>

    <material name="Air">
      <D type="density" unit="g/cm3" value="0.0012"/>
      <fraction n="0.754" ref="N"/>
      <fraction n="0.234" ref="O"/>
      <fraction n="0.012" ref="Ar"/>
    </material>

   <material name="Water">
     <MEE unit="eV" value="78"/>
     <D type="density" value="1.0" unit="g/cm3" />
     <composite n="2" ref="H" />
     <composite n="1"  ref="O" />
   </material>

    <material name="Brass">
      <D type="density" unit="g/cm3" value="8.44" />
      <fraction n="0.7" ref="Cu" />
      <fraction n="0.3" ref="Zn" />
    </material>

    <material name="ZnWO4">
      <D type="density" unit="g/cm3" value="7.87" />
      <composite n="1" ref="Zn" />    
      <composite n="1" ref="W" />    
      <composite n="4" ref="O" />    
    </material>


    <material name="HeavyLiquid">
      <D type="density" unit="g/cm3" value="2.8" />
      <fraction n="0.26" ref="Water" />
      <fraction n="0.56" ref="W" />
      <fraction n="0.02" ref="Na" />
      <fraction n="0.16" ref="O" />
    </material>


    <material name="WLSFiber">
      <D type="density" unit="g/cm3" value="1.05" />
      <composite n="8" ref="C" />
      <composite n="8" ref="H" />
    </material>


    <material name="PMMA" state="solid">
      <D value="1.19" unit="g/cm3"/>
      <composite n="5" ref="C" />
      <composite n="2" ref="O" />
      <composite n="8" ref="H" />
    </material>

    <!--Note: following material are defined by averaging grains, medium and fibers in 7mm pitch size 
      Fiber structure: WLS fiber r = 0.5 mm, with 0.02 mm thick PMMA cladding -->

    <material name="MixGrains">
      <D type="density" unit="g/cm3" value="5.6395" />
      <fraction n="0.789857" ref="ZnWO4" />
      <fraction n="0.206890" ref="HeavyLiquid" />
      <fraction n="0.002979" ref="WLSFiber" />
      <fraction n="0.000274" ref="PMMA" />
    </material>

    <material name="AirMixGrains">
      <D type="density" unit="g/cm3" value="4.4733" />
      <fraction n="0.995787" ref="ZnWO4" />
      <fraction n="0.000112" ref="Air" />
      <fraction n="0.003756" ref="WLSFiber" />
      <fraction n="0.000346" ref="PMMA" />
    </material>

    <material name="WaterMixGrains">
      <D type="density" unit="g/cm3" value="4.8895" />
      <fraction n="0.911024" ref="ZnWO4" />
      <fraction n="0.085224" ref="Water" />
      <fraction n="0.003436" ref="WLSFiber" />
      <fraction n="0.000316" ref="PMMA" />
    </material>


    <material name="CarbonFiber" state="solid">
      <MEE unit="eV" value="70.7270877537631"/>
      <D unit="g/cm3" value="1.46666666666667"/>
      <fraction n="0.794091986922138" ref="C"/>
      <fraction n="0.058408571165309" ref="H"/>
      <fraction n="0.147499441912553" ref="O"/>
    </material>

</materials>

