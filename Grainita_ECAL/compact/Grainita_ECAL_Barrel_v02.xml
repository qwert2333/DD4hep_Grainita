  <info name="Grainita_ECAL_Barrel_v02"
    title="Grainita ECAL full detector geometry (first ver.)"
    author="Fangyi Guo"
    url="None"
    status="development"
    version="0.1">
    <comment></comment>
  </info>

  <define>
    <constant name="world_size" value="10*m"/>
    <constant name="world_x" value="world_size"/>
    <constant name="world_y" value="world_size"/>
    <constant name="world_z" value="world_size"/>

    <!-- Global structure -->
    <constant name="InnerRadius"          value="220*cm"/>
    <constant name="CrystalThickness"     value="40.5*cm"/>
    <constant name="BackSpace"            value="1.8*cm"/>
    <constant name="HalfZ"                value="230*cm"/>
    <constant name="NumberOfPhiSectors"   value="72"/>
    <constant name="NumberOfZModules"     value="15"/>

    <!-- Module -->
    <constant name="FrameThickness"       value="10*mm"/>
    <constant name="SegThickness"         value="5.*mm"/>
    <constant name="ModuleTiltAngle"      value="0.5"/>       <!-- Angle in IP, Unit in degree -->

    <!-- Cell -->
    <constant name="FiberRadius"          value="0.5*mm"/>
    <constant name="CladdingThickness"    value="0.3*mm"/>
    <constant name="FiberPitchSize"       value="7*mm"/>   
    <constant name="rho0"                 value="0*mm"/>   
    <constant name="rho1"                 value="CrystalThickness/5"/>   
    <constant name="rho2"                 value="CrystalThickness+10*mm"/>   


  </define>

  <includes>
    <gdmlFile  ref="elements.xml"/>
    <gdmlFile  ref="material.xml"/>
  </includes>
  

  <!-- Define visualization attributes. Vis attributes contains an
       alpha value for transparency, r-g-b for color, show daughters possibility true/false
       and visibile (or invisible) true/false.
  -->
  <display>
    <vis name="Invisible"        alpha="0.0" r="0.0" g="0.0"  b="0.0"   showDaughters="false" visible="false"/>
    <vis name="SeeThrough"       alpha="0.0" r="0.0" g="0.0"  b="0.0"   showDaughters="true"  visible="false"/>

    <vis name="CaloVis" alpha="1.0" r="0.0" g="1.0" b="0.0" showDaughters="false" visible="true"/>
    <vis name="CaloLayerVis" alpha="1.0" r="0.0" g="0.0" b="1.0" showDaughters="true" visible="true"/>
    <vis name="CarbonFrameVis" alpha="1.0" r="0.375" g="0.375" b="0.375" showDaughters="true" visible="true"/>
    <vis name="SensitiveVis" alpha="1.0" r="0.4" g="0.7" b="1.0" showDaughters="false" visible="true"/>
    <vis name="WLSFiberVis" alpha="1.0" r="1.0" g="0.3" b="0.2" showDaughters="true" visible="true"/>
    <vis name="FiberCladdingVis" alpha="1.0" r="1.0" g="0.6" b="0.2" showDaughters="true" visible="true"/>
  </display>

  <!-- Define the detector. A detector has a name, type to be returned in .cpp file with 
       DECLARE_DETELEMENT(type,create_detector_c++method), vis attributes (optional),
       and sensitive-detector (true/false), if sensitive="true" a readout must the passed.
       If a detector contains sub-detectors, their information must be included as below.
  -->
  <detectors>
    <detector name="Grainita_ECAL_Barrel_v02" type="Grainita_ECAL_Barrel_v02" vis="CaloVis" id ="10" readout="GrainitaEcalBarrelRO" material="MixGrains">
    <type_flags type=" DetType_CALORIMETER + DetType_ELECTROMAGNETIC + DetType_BARREL"/>
    </detector>
  </detectors>



  <readouts>
    <readout name="GrainitaEcalBarrelRO">
      <segmentation type="FCCSWModularRhoPhiTheta_k4geo"
              phi_bins="1975"
              grid_size_theta="0.0032"
              rho_bins="rho0 rho1 rho2"
              offset_R="InnerRadius+FrameThickness"/>
      <id>system:5,stave:6,sector:7,phi:-16,theta:16,rho:4</id>
    </readout>
  </readouts> 


</lccdd>
